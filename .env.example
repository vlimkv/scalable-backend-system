APP_NAME=OpsFlow API
APP_ENV=local
DEBUG=true

API_V1_PREFIX=/api/v1

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=opsflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/opsflow
SYNC_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/opsflow

JWT_SECRET_KEY=change_me_super_secret
JWT_REFRESH_SECRET_KEY=change_me_refresh_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7